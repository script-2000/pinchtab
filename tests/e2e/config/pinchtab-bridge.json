{
  "server": {
    "bind": "0.0.0.0",
    "port": "9999",
    "token": "e2e-bridge-token"
  },
  "browser": {
    "extraFlags": "--no-sandbox --disable-dev-shm-usage"
  },
  "security": {
    "allowEvaluate": false,
    "allowDownload": false,
    "allowUpload": false,
    "idpi": {
      "enabled": true,
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "::1",
        "fixtures"
      ]
    }
  }
}
