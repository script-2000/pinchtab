{
  "server": {
    "bind": "0.0.0.0",
    "port": "9999"
  },
  "browser": {
    "extraFlags": "--no-sandbox --disable-dev-shm-usage"
  },
  "instanceDefaults": {
    "maxTabs": 10
  },
  "multiInstance": {
    "strategy": "always-on",
    "allocationPolicy": "fcfs",
    "restart": {
      "maxRestarts": 20,
      "initBackoffSec": 2,
      "maxBackoffSec": 60,
      "stableAfterSec": 300
    }
  },
  "security": {
    "allowEvaluate": true,
    "allowDownload": true,
    "allowUpload": true,
    "idpi": {
      "enabled": true,
      "allowedDomains": [
        "localhost",
        "127.0.0.1",
        "::1",
        "fixtures"
      ]
    }
  }
}
