{
  "manifest_version": 3,
  "name": "PinchTab API Test Extension",
  "version": "1.0.0",
  "description": "Second extension for testing additive loading",
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
