{
  "manifest_version": 3,
  "name": "PinchTab Test Extension",
  "version": "1.0.0",
  "description": "Minimal extension for E2E testing",
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
